{
  "adapter": "bytefence-vibe-explicit-tool",
  "schemaVersion": "0.1",
  "target": {
    "distribution": "mistral-vibe",
    "version": "2.19.1",
    "upstreamCommit": "30792a4cac2c2e5173c6b5a98739fbbf36324545",
    "python": ">=3.12"
  },
  "integration": {
    "projectTool": "bytefence_apply",
    "sameNameEditOverride": false,
    "hooksExperimental": true,
    "beforeToolCanDeny": true,
    "afterToolCanRollback": false
  },
  "projectToolConfigContract": {
    "fixedFieldsExact": {
      "permission": "ask",
      "broker_command": [
        "agent-proof",
        "bytefence-apply"
      ],
      "root": ".",
      "policy_path": ".vibe/bytefence-policy.json",
      "receipt_directory": ".vibe/bytefence-receipts",
      "receipt_profile": "public",
      "timeout_seconds": 60.0
    },
    "variableFields": {
      "workspace_id": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1024
      }
    }
  },
  "codeIntegrity": {
    "algorithm": "sha256",
    "files": {
      ".vibe/tools/_bytefence_runtime.py": "640d6014d15029284cc2fe86a50822e1cf1a3e46852033926500beb3cb1937a0",
      ".vibe/tools/bytefence_apply.py": "e8222dab1345cce2743ed5df2a84d84467109442c249af5d6336b8922dcbbd4e",
      ".vibe/hooks/bytefence_guard.py": "690eba42e347ef8de89b7d957222c2dda0f8150d5dfeda8c5e232202cbe58ab7"
    }
  },
  "runtimeToolContract": {
    "selectionEngine": "vibe.core.tools.manager.ToolManager",
    "singleVariantRequired": true,
    "tools": {
      "bytefence_apply": {
        "sourceRoot": "project",
        "relativePath": ".vibe/tools/bytefence_apply.py",
        "class": "ByteFenceApply",
        "sha256": "e8222dab1345cce2743ed5df2a84d84467109442c249af5d6336b8922dcbbd4e"
      },
      "read_file": {
        "sourceRoot": "vibe-package",
        "relativePath": "core/tools/builtins/read_file.py",
        "module": "vibe.core.tools.builtins.read_file",
        "class": "ReadFile",
        "sha256": "1bc749984712a2b80a4588db08178165825ca46d0d8414ce6b7d7c75451abdca"
      },
      "grep": {
        "sourceRoot": "vibe-package",
        "relativePath": "core/tools/builtins/grep.py",
        "module": "vibe.core.tools.builtins.grep",
        "class": "Grep",
        "sha256": "e214193eefbb301b59ce6cac5ddae0d4f2469952087e60ac145b49aa9510000a"
      },
      "web_fetch": {
        "sourceRoot": "vibe-package",
        "relativePath": "core/tools/builtins/web_fetch.py",
