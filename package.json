{
  "name": "agent-proof-kit",
  "version": "0.3.0",
  "description": "Deterministic release gates for AI agent runs, backed by synthetic fixtures.",
  "type": "module",
  "private": false,
  "bin": {
    "agent-proof": "./bin/agent-proof.js",
    "agent-proof-mcp": "./bin/agent-proof-mcp.js"
  },
  "files": [
    "bin/",
    "src/",
    "schemas/",
    "policies/",
    "examples/",
    "docs/",
    "action.yml"
  ],
  "scripts": {
    "test:unit": "node --test tests/unit/*.test.js",
    "test:schema": "node --test tests/schema/*.test.js",
    "test:adapter": "node --test tests/adapter/*.test.js",
    "test:diff": "node --test tests/diff/*.test.js",
    "test:sarif": "node --test tests/sarif/*.test.js",
    "test:cli": "node --test tests/cli/*.test.js",
    "test:mcp": "node --test tests/mcp/*.test.js",
    "test:pack": "node --test tests/pack/*.test.js",
    "scan:leaks": "node bin/agent-proof.js scan --path . --policy policies/default-policy.json --format text",
    "scan:generated": "node bin/agent-proof.js scan --path docs/generated --policy policies/default-policy.json --format text",
    "report:generate": "node scripts/generate-report.js",
    "report:verify": "node scripts/check-generated-report.js",
    "artifacts:generate": "node scripts/generate-machine-artifacts.js",
    "artifacts:verify": "node scripts/check-machine-artifacts.js",
    "coverage:generate": "node scripts/generate-gate-coverage.js",
    "coverage:verify": "node scripts/check-gate-coverage.js",
    "refresh": "npm run report:generate && npm run artifacts:generate && npm run coverage:generate",
    "verify": "npm run test:unit && npm run test:schema && npm run test:adapter && npm run test:diff && npm run test:sarif && npm run test:cli && npm run test:mcp && npm run test:pack && npm run report:verify && npm run artifacts:verify && npm run coverage:verify && npm run scan:leaks && npm run scan:generated"
  },
  "engines": {
    "node": ">=20.11"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/guillaumevele/agent-proof-kit.git"
  },
  "keywords": [
    "ai-agents",
    "agent-evaluation",
    "evals",
    "release-gates",
    "workflow-safety",
    "synthetic-data"
  ],
  "author": "Guillaume Vele",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
