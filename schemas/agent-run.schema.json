{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/guillaumevele/agent-proof-kit/schemas/agent-run.schema.json",
  "title": "Agent Proof Kit Agent Run",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "runId", "subject", "synthetic", "actions", "outputs", "evidence"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "synthetic": {
      "type": "boolean"
    },
    "generatedAt": {
      "type": "string"
    },
    "agent": {
      "type": "object",
      "additionalProperties": true
    },
    "objectives": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/output"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      }
    }
  },
  "$defs": {
    "action": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "type", "target", "approval", "outcome"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "approval": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string"
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "channel", "content"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "channel": {
          "type": "string",
          "minLength": 1
        },
        "content": {
          "type": "string"
        },
        "claims": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/claim"
          }
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": true,
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "string"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "kind", "result"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string"
        },
        "result": {
          "type": "string",
          "minLength": 1
        },
        "excerpt": {
          "type": "string"
        }
      }
    }
  }
}
